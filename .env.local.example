# =============================================
# AssetFlow Next.js — Environment Variables
# Copy this file to .env.local and fill in values
# =============================================

# ── DATABASE ───────────────────────────────
# PostgreSQL connection string
# Local dev example: postgresql://postgres:password@localhost:5432/assetflow
# Neon example:      postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/assetflow?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/assetflow"

# ── AUTH.JS ────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET="REPLACE_WITH_32_CHAR_HEX_SECRET"
NEXTAUTH_URL="http://localhost:3000"

# ── RATE LIMITING (Upstash Redis) ──────────
# Leave empty to use in-process fallback (no Redis needed for local dev)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── FILE / BLOB STORAGE ────────────────────
# Option A: Vercel Blob
# BLOB_READ_WRITE_TOKEN=""

# Option B: Azure Blob Storage
# AZURE_STORAGE_CONNECTION_STRING=""
# AZURE_STORAGE_CONTAINER_NAME="assetflow-documents"

# ── CRON JOBS ──────────────────────────────
# Secret header value for securing cron endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET="REPLACE_WITH_CRON_SECRET"

# ── APP ────────────────────────────────────
NODE_ENV=development
TZ=Asia/Kolkata


# ===================
# EMAIL & NOTIFICATIONS
# ===================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
