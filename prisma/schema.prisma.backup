// ============================================================
// AssetFlow — Enterprise Asset & Resource Management System
// Prisma Schema (PostgreSQL)
// ============================================================
// Screens 1–10 from the AssetFlow problem statement. Auth is kept
// deliberately simple: NextAuth CredentialsProvider (email + password,
// JWT session strategy — no Account/Session tables needed) plus an
// OTP flow for email verification / password reset / passwordless login.
// No OAuth, no MFA.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ================================================================
// ENUMS
// ================================================================

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum ActiveStatus {
  ACTIVE
  INACTIVE
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  LOGIN
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  DAMAGED
}

enum AllocationTargetType {
  EMPLOYEE
  DEPARTMENT
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  OVERDUE
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum BookingStatus {
  UPCOMING
  ONGOING
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  TECHNICIAN_ASSIGNED
  IN_PROGRESS
  RESOLVED
}

enum AuditCycleStatus {
  PLANNED
  IN_PROGRESS
  CLOSED
}

enum AuditItemStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
}

enum DiscrepancyResolution {
  OPEN
  RESOLVED
  WRITTEN_OFF
}

enum NotificationType {
  ASSET_ASSIGNED
  ASSET_RETURNED
  MAINTENANCE_REQUESTED
  MAINTENANCE_APPROVED
  MAINTENANCE_REJECTED
  MAINTENANCE_RESOLVED
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_REMINDER
  TRANSFER_REQUESTED
  TRANSFER_APPROVED
  TRANSFER_REJECTED
  OVERDUE_RETURN
  AUDIT_DISCREPANCY
  AUDIT_CYCLE_ASSIGNED
  SYSTEM
}

enum LogAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  ALLOCATE
  RETURN
  TRANSFER
  BOOK
  CANCEL
  LOGIN
  LOGOUT
  LOGIN_FAILED
  ROLE_CHANGE
  PASSWORD_CHANGE
  PERMISSION_CHANGE
  STATUS_CHANGE
  OTHER
}

// ================================================================
// USERS / EMPLOYEE DIRECTORY  (Screen 1, Screen 3 - Tab C)
// ================================================================

model User {
  id           String       @id @default(cuid())
  employeeCode String?      @unique // optional human-readable ID, e.g. EMP-0001
  fullName     String
  email        String       @unique
  password     String // bcrypt hash — required, this app has no OAuth fallback
  emailVerified   Boolean   @default(false)
  emailVerifiedAt DateTime?
  avatarUrl    String?
  phone        String?

  // Signup always creates EMPLOYEE. Admin promotes to DEPARTMENT_HEAD /
  // ASSET_MANAGER from the Employee Directory screen only — never at signup.
  role   Role         @default(EMPLOYEE)
  status ActiveStatus @default(ACTIVE)

  departmentId String?
  department   Department? @relation("DepartmentMembers", fields: [departmentId], references: [id])

  // Per-user permission overrides on top of the role's RolePermission defaults.
  permissionOverrides UserPermission[]

  isBlocked   Boolean   @default(false)
  blockedAt   DateTime?
  blockReason String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Auth history (NextAuth uses JWT sessions here, so no Account/Session tables)
  loginHistory  LoginHistory[]
  logoutHistory LogoutHistory[]

  // Domain relations
  headOfDepartments           Department[]         @relation("DepartmentHead")
  registeredAssets            Asset[]              @relation("AssetRegisteredBy")
  allocationsReceived         Allocation[]         @relation("AllocationEmployee")
  allocationsAssignedBy       Allocation[]         @relation("AllocationAssignedBy")
  transferRequestsFrom        TransferRequest[]    @relation("TransferFromEmployee")
  transferRequestsTo          TransferRequest[]    @relation("TransferToEmployee")
  transferRequestedBy         TransferRequest[]    @relation("TransferRequestedBy")
  transferApprovedBy          TransferRequest[]    @relation("TransferApprovedBy")
  bookings                    Booking[]            @relation("BookingUser")
  maintenanceRequestsRaised   MaintenanceRequest[] @relation("MaintenanceRaisedBy")
  maintenanceRequestsApproved MaintenanceRequest[] @relation("MaintenanceApprovedBy")
  auditCyclesCreated          AuditCycle[]         @relation("AuditCycleCreatedBy")
  auditCycleAssignments       AuditCycleAuditor[]
  auditItemsVerified          AuditItem[]          @relation("AuditItemAuditor")
  notifications                Notification[]
  activityLogs                 ActivityLog[]

  @@index([departmentId])
  @@index([role])
}

// One-time codes for email verification, password reset, and passwordless
// (OTP) login. Never store the raw code — hash it the same way you hash
// passwords and compare hashes on verify.
model OtpCode {
  id         String     @id @default(cuid())
  identifier String // email the OTP was sent to
  codeHash   String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  attempts   Int        @default(0) // lock out after N failed checks
  createdAt  DateTime   @default(now())

  @@index([identifier, purpose])
  @@index([expiresAt])
}

// Security audit trail — every login attempt, success or failure.
// Postgres has no TTL index; prune rows older than N days with a
// scheduled job/cron instead.
model LoginHistory {
  id            String   @id @default(cuid())
  userId        String
  method        String   @default("PASSWORD") // "PASSWORD" | "OTP"
  success       Boolean  @default(false)
  failureReason String?
  ipAddress     String?
  userAgent     String?
  timestamp     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

model LogoutHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
}

// ================================================================
// PERMISSIONS
// ================================================================
// Two layers, both DB-backed so an Admin can adjust access without a
// redeploy:
//   1. RolePermission — the default permission set for each Role.
//      Seed this once (mirrors the old ROLE_PERMISSIONS map in
//      constants.js) and edit it from an Admin screen going forward.
//   2. UserPermission — per-user grant/revoke on top of the role default,
//      for the "this one Employee also needs booking:cancel" case.
//
// Effective permissions for a user = RolePermission[user.role]
//   plus UserPermission rows with granted = true
//   minus UserPermission rows with granted = false
// Resolve this once at login/refresh and cache it on the JWT (as your
// existing middleware.ts already does with token.permissions), rather
// than hitting the DB on every request.

model Permission {
  id          String  @id @default(cuid())
  key         String  @unique // e.g. "asset:create", "booking:cancel", "audit:close"
  description String?
  category    String? // e.g. "Asset", "Booking", "Maintenance", "Audit" — for grouping in the Admin UI

  userOverrides   UserPermission[]
  rolePermissions RolePermission[]

  createdAt DateTime @default(now())

  @@index([key])
  @@index([category])
}

model RolePermission {
  id           String @id @default(cuid())
  role         Role
  permissionId String

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([role, permissionId])
  @@index([role])
}

model UserPermission {
  id           String  @id @default(cuid())
  userId       String
  permissionId String
  // true  = explicit grant (adds a permission the role doesn't have by default)
  // false = explicit revoke (removes a permission the role would otherwise have)
  granted      Boolean @default(true)
  grantedById  String? // Admin who made the change, for audit purposes
  reason       String?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, permissionId])
  @@index([userId])
}

// ================================================================
// ORGANIZATION SETUP  (Screen 3 - Tabs A & B)
// ================================================================

model Department {
  id       String       @id @default(cuid())
  name     String       @unique
  headId   String?
  parentId String?
  status   ActiveStatus @default(ACTIVE)

  head     User?        @relation("DepartmentHead", fields: [headId], references: [id])
  parent   Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentHierarchy")

  members     User[]       @relation("DepartmentMembers")
  assets      Asset[]      @relation("AssetDepartment")
  allocations Allocation[] @relation("AllocationDepartment")
  bookings    Booking[]    @relation("BookingDepartment")
  auditCycles AuditCycle[] @relation("AuditCycleDepartment")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([parentId])
}

model AssetCategory {
  id          String @id @default(cuid())
  name        String @unique
  description String?

  // Category-specific optional fields, e.g. { "warrantyPeriodMonths": 24 }
  customFields Json?

  assets Asset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Guarantees gap-free, race-safe asset tags (AF-0001, AF-0002, ...).
// App code should increment this inside the same transaction as the
// Asset.create() call rather than doing a count()+1.
model Counter {
  id    String @id // e.g. "assetTag"
  value Int    @default(0)
}

// ================================================================
// ASSETS  (Screen 4)
// ================================================================

model Asset {
  id           String @id @default(cuid())
  assetTag     String @unique // auto-generated, e.g. AF-0001
  name         String
  categoryId   String
  serialNumber String?
  qrCode       String? @unique

  acquisitionDate DateTime?
  acquisitionCost Decimal?  @db.Decimal(14, 2) // kept for ranking/reports only — not linked to accounting

  condition AssetCondition @default(GOOD)
  location  String?
  status    AssetStatus    @default(AVAILABLE)

  isBookable Boolean @default(false) // "shared/bookable" flag

  departmentId   String? // owning department, if any
  registeredById String

  // Optional cover photo, stored directly as a blob.
  photo         Bytes?
  photoMimeType String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  category     AssetCategory @relation(fields: [categoryId], references: [id])
  department   Department?   @relation("AssetDepartment", fields: [departmentId], references: [id])
  registeredBy User          @relation("AssetRegisteredBy", fields: [registeredById], references: [id])

  documents           AssetDocument[]
  allocations         Allocation[]
  transferRequests    TransferRequest[]
  bookings            Booking[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]
  history             AssetHistory[]

  @@index([categoryId])
  @@index([departmentId])
  @@index([status])
  @@index([serialNumber])
}

// Extra photos/documents per asset — kept separate from Asset.photo so an
// asset can have one cover image plus supporting docs (invoices, warranty
// cards, extra angles) without bloating the Asset row itself. `data` is
// optional in case a deployment prefers external blob storage + `url`.
model AssetDocument {
  id         String   @id @default(cuid())
  assetId    String
  fileName   String
  mimeType   String
  data       Bytes?
  url        String?
  uploadedAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

// Append-only per-asset trail (allocation, return, transfer, maintenance,
// disposal, status change...) — powers the "Per-asset history" requirement.
model AssetHistory {
  id          String   @id @default(cuid())
  assetId     String
  actionType  String // CREATION | ALLOCATION | RETURN | TRANSFER | MAINTENANCE_START | DISPOSAL | ...
  performedBy String
  notes       String?
  actionDate  DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([actionDate])
}

// ================================================================
// ALLOCATION & TRANSFER  (Screen 5)
// ================================================================

model Allocation {
  id         String               @id @default(cuid())
  assetId    String
  targetType AllocationTargetType
  employeeId String?
  departmentId String?

  allocationDate     DateTime  @default(now())
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?

  status AllocationStatus @default(ACTIVE)

  conditionAtAllocation AssetCondition?
  conditionAtReturn     AssetCondition?
  returnNotes           String?

  assignedById String
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asset      Asset       @relation(fields: [assetId], references: [id])
  employee   User?       @relation("AllocationEmployee", fields: [employeeId], references: [id])
  department Department? @relation("AllocationDepartment", fields: [departmentId], references: [id])
  assignedBy User        @relation("AllocationAssignedBy", fields: [assignedById], references: [id])

  transferRequests TransferRequest[]

  @@index([assetId])
  @@index([employeeId])
  @@index([status])
  @@index([expectedReturnDate]) // overdue-allocation sweep
}

model TransferRequest {
  id                  String @id @default(cuid())
  assetId             String
  currentAllocationId String?

  fromEmployeeId String?
  toEmployeeId   String?

  requestedById String
  approvedById  String?

  status TransferStatus @default(REQUESTED)
  notes  String?

  requestedAt DateTime  @default(now())
  approvedAt  DateTime?
  completedAt DateTime?

  asset             Asset       @relation(fields: [assetId], references: [id])
  currentAllocation Allocation? @relation(fields: [currentAllocationId], references: [id])
  fromEmployee      User?       @relation("TransferFromEmployee", fields: [fromEmployeeId], references: [id])
  toEmployee        User?       @relation("TransferToEmployee", fields: [toEmployeeId], references: [id])
  requestedBy       User        @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  approvedBy        User?       @relation("TransferApprovedBy", fields: [approvedById], references: [id])

  @@index([assetId])
  @@index([status])
}

// ================================================================
// RESOURCE BOOKING  (Screen 6)
// ================================================================

model Booking {
  id           String        @id @default(cuid())
  assetId      String
  userId       String
  departmentId String?

  startTime DateTime
  endTime   DateTime
  purpose   String?
  status    BookingStatus @default(UPCOMING)

  cancelledAt  DateTime?
  cancelReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asset      Asset       @relation(fields: [assetId], references: [id])
  user       User        @relation("BookingUser", fields: [userId], references: [id])
  department Department? @relation("BookingDepartment", fields: [departmentId], references: [id])

  // Composite index speeds up the overlap-validation query
  // (WHERE assetId = ? AND startTime < ? AND endTime > ?).
  @@index([assetId, startTime, endTime])
  @@index([userId])
  @@index([status])
}

// ================================================================
// MAINTENANCE  (Screen 7)
// ================================================================

model MaintenanceRequest {
  id           String @id @default(cuid())
  assetId      String
  raisedById   String
  approvedById String?

  issueDescription String
  priority         MaintenancePriority @default(MEDIUM)
  status           MaintenanceStatus   @default(PENDING)

  photo         Bytes?
  photoMimeType String?

  technician      String?
  cost            Decimal? @db.Decimal(12, 2)
  resolutionNotes String?

  requestedAt          DateTime  @default(now())
  approvedAt           DateTime?
  technicianAssignedAt DateTime?
  startedAt            DateTime?
  resolvedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asset      Asset  @relation(fields: [assetId], references: [id])
  raisedBy   User   @relation("MaintenanceRaisedBy", fields: [raisedById], references: [id])
  approvedBy User?  @relation("MaintenanceApprovedBy", fields: [approvedById], references: [id])

  @@index([assetId])
  @@index([status])
}

// ================================================================
// ASSET AUDIT  (Screen 8)
// ================================================================

model AuditCycle {
  id                String @id @default(cuid())
  name              String
  scopeDepartmentId String?
  scopeLocation     String?

  startDate DateTime
  endDate   DateTime

  status AuditCycleStatus @default(PLANNED)

  createdById String
  closedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  scopeDepartment Department? @relation("AuditCycleDepartment", fields: [scopeDepartmentId], references: [id])
  createdBy       User        @relation("AuditCycleCreatedBy", fields: [createdById], references: [id])

  auditors AuditCycleAuditor[]
  items    AuditItem[]

  @@index([status])
}

model AuditCycleAuditor {
  id           String @id @default(cuid())
  auditCycleId String
  auditorId    String

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  auditor    User       @relation(fields: [auditorId], references: [id])

  assignedAt DateTime @default(now())

  @@unique([auditCycleId, auditorId])
}

model AuditItem {
  id           String @id @default(cuid())
  auditCycleId String
  assetId      String
  auditorId    String?

  status     AuditItemStatus @default(PENDING)
  notes      String?
  verifiedAt DateTime?

  discrepancy DiscrepancyReport?

  auditCycle AuditCycle @relation(fields: [auditCycleId], references: [id], onDelete: Cascade)
  asset      Asset      @relation(fields: [assetId], references: [id])
  auditor    User?      @relation("AuditItemAuditor", fields: [auditorId], references: [id])

  // One verification row per asset per cycle
  @@unique([auditCycleId, assetId])
  @@index([status])
}

// Auto-generated whenever an AuditItem is flagged MISSING or DAMAGED.
model DiscrepancyReport {
  id           String                @id @default(cuid())
  auditItemId  String                @unique
  assetId      String
  description  String?
  resolution   DiscrepancyResolution @default(OPEN)
  resolvedById String?
  resolvedAt   DateTime?

  createdAt DateTime @default(now())

  auditItem AuditItem @relation(fields: [auditItemId], references: [id], onDelete: Cascade)

  @@index([resolution])
}

// ================================================================
// NOTIFICATIONS & ACTIVITY LOGS  (Screen 10)
// ================================================================

model Notification {
  id       String           @id @default(cuid())
  userId   String
  type     NotificationType
  title    String
  message  String
  linkPath String?
  isRead   Boolean          @default(false)

  relatedEntityType String? // "Asset" | "Booking" | "MaintenanceRequest" | ...
  relatedEntityId   String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// Full log of who did what, when — separate from AssetHistory (which is
// asset-scoped/user-facing) so it can capture non-asset actions too
// (login, role changes, department edits, permission changes, etc.).
model ActivityLog {
  id        String    @id @default(cuid())
  userId    String?
  action    LogAction
  tableName String
  recordId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  createdAt DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([tableName, recordId])
  @@index([userId])
  @@index([createdAt])
}
