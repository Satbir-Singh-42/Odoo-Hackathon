// =============================================
// Prisma Schema — AssetFlow
// Converted from MSSQL schema v13.1
// Target: PostgreSQL
// =============================================

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// AUTH.JS REQUIRED TABLES
// =============================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// =============================================
// 1. ASSET TYPES (Combined Categories + Types)
// =============================================

model AssetType {
  id           Int      @id @default(autoincrement())
  categoryName String   @db.VarChar(20)
  typeName     String   @db.VarChar(50)
  createdAt    DateTime @default(now())

  assets Asset[]

  @@unique([categoryName, typeName])
  @@index([categoryName])
  @@map("asset_types")
}

// =============================================
// 2. VENDORS
// =============================================

model Vendor {
  id         String   @id @db.VarChar(20)
  vendorName String   @db.VarChar(150)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)
  isBlocked  Boolean  @default(false)

  assets Asset[]

  @@map("vendors")
}

// =============================================
// 3. USERS (also serves as Auth.js User model)
// =============================================

model User {
  id                 String    @id @db.VarChar(20)  // EmployeeID
  fullName           String    @db.VarChar(100)
  department         String?   @db.VarChar(50)
  email              String?   @db.VarChar(255)
  password           String?   @db.VarChar(255)
  role               UserRole  @default(Viewer)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  isDeleted          Boolean   @default(false)
  isBlocked          Boolean   @default(false)
  lastLogoutAt       DateTime?
  managedCategories  String?   @default("ALL") @db.VarChar(500)

  // Auth.js relations
  accounts           Account[]
  sessions           Session[]

  // App relations
  allocations        Allocation[]
  maintenanceReports Maintenance[]      @relation("ReportedByUser")
  assetHistory       AssetHistory[]
  inAppNotifications InAppNotification[]

  @@index([role])
  @@map("users")
}

enum UserRole {
  Admin
  Manager
  Viewer
}

// =============================================
// 4. ASSETS (Core Registry)
// =============================================

model Asset {
  id              Int      @id @default(autoincrement())
  assetCode       String   @unique @db.VarChar(20)
  assetName       String   @db.VarChar(150)
  assetTypeId     Int

  // Purchase
  invoiceNumber   String?  @db.VarChar(50)
  invoiceDate     DateTime? @db.Date
  vendorId        String?  @db.VarChar(20)
  purchasePrice   Decimal  @default(0) @db.Decimal(18, 2)
  purchaseNumber  String?  @db.VarChar(50)
  prNumber        String?  @db.VarChar(50)
  importBillUrl   String?  @db.VarChar(500)

  // Hardware Specs (IMMUTABLE)
  serialNumber    String?  @db.VarChar(50)
  model           String?  @db.VarChar(50)
  ram             String?  @db.VarChar(20)
  storage         String?  @db.VarChar(20)
  processor       String?  @db.VarChar(50)
  macAddress      String?  @db.VarChar(20)

  // Networking Specs (IMMUTABLE)
  portCount       Int?
  portSpeed       String?  @db.VarChar(20)

  // Inventory
  totalQuantity     Int    @default(1)
  allocatedQuantity Int    @default(0)

  // Software
  licenseExpiryDate DateTime? @db.Date
  licenseType       LicenseType?

  // Status
  status          AssetStatus @default(Available)
  disposalDate    DateTime?   @db.Date
  disposalReason  String?     @db.VarChar(255)
  condition       AssetCondition?

  // Bulk Order
  isBulkOrder       Boolean @default(false)
  bulkOrderParentId Int?
  bulkOrderIndex    Int?

  // Audit
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)

  // Relations
  assetType       AssetType     @relation(fields: [assetTypeId], references: [id])
  vendor          Vendor?       @relation(fields: [vendorId], references: [id])
  bulkParent      Asset?        @relation("BulkChildren", fields: [bulkOrderParentId], references: [id])
  bulkChildren    Asset[]       @relation("BulkChildren")

  allocations     Allocation[]
  parentAllocations Allocation[] @relation("ParentAssetAllocations")
  maintenance     Maintenance[]
  history         AssetHistory[]
  parentHistory   AssetHistory[] @relation("ParentAssetHistory")
  notifications   InAppNotification[]
  documents       Document[]

  @@index([status])
  @@index([assetTypeId])
  @@index([vendorId])
  @@index([updatedAt(sort: Desc)])
  @@index([assetCode])
  @@index([isDeleted, status])
  @@map("assets")
}

enum AssetStatus {
  Available
  Allocated
  Partially_Allocated @map("Partially Allocated")
  Under_Maintenance   @map("Under Maintenance")
  Disposed
  License_Expired     @map("License Expired")
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum LicenseType {
  PERPETUAL
  SUBSCRIPTION
  SAAS
  TRIAL
  VOLUME
  ENTERPRISE
}

// =============================================
// 5. ALLOCATIONS
// =============================================

model Allocation {
  id                   Int      @id @default(autoincrement())
  assetId              Int
  employeeId           String?  @db.VarChar(20)
  parentAssetId        Int?
  allocationDate       DateTime @default(now())
  returnDate           DateTime?

  // Deployment fields (MUTABLE per allocation)
  installationLocation String?  @db.VarChar(150)
  ipAddress            String?  @db.VarChar(45)
  operatingSystem      String?  @db.VarChar(50)

  // Condition tracking
  conditionAtAllocation AssetCondition @default(GOOD)
  conditionAtReturn     AssetCondition?

  // Status & Notes
  status        AllocationStatus @default(ACTIVE)
  returnNotes   String?          @db.VarChar(255)
  assignedBy    String?          @db.VarChar(100)
  returnedBy    String?          @db.VarChar(100)
  createdAt     DateTime         @default(now())
  isDeleted     Boolean          @default(false)

  // Relations
  asset        Asset  @relation(fields: [assetId], references: [id])
  employee     User?  @relation(fields: [employeeId], references: [id])
  parentAsset  Asset? @relation("ParentAssetAllocations", fields: [parentAssetId], references: [id])

  @@index([assetId])
  @@index([employeeId])
  @@index([parentAssetId])
  @@index([status])
  @@index([returnDate])
  @@index([ipAddress])
  @@map("allocations")
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  REVOKED
  EXPIRED
}

// =============================================
// 6. MAINTENANCE
// =============================================

model Maintenance {
  id             Int      @id @default(autoincrement())
  assetId        Int
  scheduledDate  DateTime
  completedDate  DateTime?
  description    String   @db.VarChar(255)
  notes          String?  @db.Text
  status         MaintenanceStatus @default(Scheduled)
  technician     String?  @db.VarChar(100)
  cost           Decimal  @default(0) @db.Decimal(18, 2)
  frequency      MaintenanceFrequency?
  isBulkGroupRecord Boolean @default(false)
  unitCount      Int?
  reportedBy     String?  @db.VarChar(20)
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  asset          Asset  @relation(fields: [assetId], references: [id])
  reporter       User?  @relation("ReportedByUser", fields: [reportedBy], references: [id])
  notifications  NotificationQueue[]

  @@index([assetId])
  @@index([scheduledDate])
  @@index([status])
  @@index([isDeleted, status])
  @@map("maintenance")
}

enum MaintenanceStatus {
  Scheduled
  In_Progress @map("In Progress")
  Completed
  Cancelled
  Reported
}

enum MaintenanceFrequency {
  Monthly
  Quarterly
  Half_Yearly  @map("Half-Yearly")
  Yearly
  One_Time     @map("One-Time")
}

// =============================================
// 7. ASSET HISTORY (Business Log)
// =============================================

model AssetHistory {
  id              Int      @id @default(autoincrement())
  assetId         Int
  employeeId      String?  @db.VarChar(20)
  actionType      String   @db.VarChar(50)
  actionDate      DateTime @default(now())
  performedBy     String?  @db.VarChar(100)
  notes           String?  @db.Text
  condition       String?  @db.VarChar(20)
  parentAssetId   Int?
  parentAssetName String?  @db.VarChar(150)

  // Relations
  asset       Asset  @relation(fields: [assetId], references: [id])
  employee    User?  @relation(fields: [employeeId], references: [id])
  parentAsset Asset? @relation("ParentAssetHistory", fields: [parentAssetId], references: [id])

  @@index([assetId])
  @@index([employeeId])
  @@index([actionDate(sort: Desc)])
  @@index([actionType])
  @@index([parentAssetId])
  @@index([assetId, actionType])
  @@map("asset_history")
}

// =============================================
// 8. AUDIT LOG (System Log)
// =============================================

model AuditLog {
  id             Int      @id @default(autoincrement())
  tableName      String   @db.VarChar(50)
  recordId       String?  @db.VarChar(50)
  action         AuditAction
  oldValues      String?  @db.Text
  newValues      String?  @db.Text
  changedBy      String?  @db.VarChar(100)
  changedAt      DateTime @default(now())
  additionalInfo String?  @db.Text
  isDeleted      Boolean  @default(false)

  @@index([tableName, recordId])
  @@index([changedAt(sort: Desc)])
  @@index([changedBy, changedAt(sort: Desc)])
  @@index([action])
  @@index([tableName, action, recordId])
  @@map("audit_logs")
}

enum AuditAction {
  INSERT
  ASSET_INSERT
  UPDATE
  DELETE
  ALLOCATE
  RETURN
  MAINTENANCE
  MAINTENANCE_UPDATE
  MAINTENANCE_START
  MAINTENANCE_END
  MAINTENANCE_SCHEDULE
  MAINTENANCE_CANCEL
  DISPOSE
  LICENSE_RENEWED
  ROLE_CHANGE
  PASSWORD_CHANGE
  USER_BLOCK_TOGGLE
  UNAUTHORIZED_ACCESS
  LOGIN
  LOGOUT
  LOGIN_FAILED
  CREATION
  DELETION
  EMAIL_SENT
  EMAIL_SUPPRESSED
  EMAIL_MERGED
}

// =============================================
// 9. SYSTEM SETTINGS
// =============================================

model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String?  @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// =============================================
// 10. NOTIFICATION QUEUE
// =============================================

model NotificationQueue {
  id               Int      @id @default(autoincrement())
  recipient        String?  @db.VarChar(1000)
  subject          String   @db.VarChar(255)
  body             String   @db.Text
  type             String   @db.VarChar(50)
  status           NotificationStatus @default(PENDING)
  createdAt        DateTime @default(now())
  scheduledFor     DateTime @default(now())
  sentAt           DateTime?
  errorMessage     String?  @db.Text
  retryCount       Int      @default(0)
  cc               String?  @db.VarChar(1000)
  metadata         String?  @db.Text
  maintenanceId    Int?
  maintenanceEmailType String? @db.VarChar(20)
  recipientType    String?  @db.VarChar(50)
  recipientLabel   String?  @db.VarChar(255)
  suppressedBy     String?  @db.VarChar(100)
  suppressedAt     DateTime?

  maintenance      Maintenance? @relation(fields: [maintenanceId], references: [id])

  @@index([status])
  @@index([maintenanceId])
  @@map("notification_queue")
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SUPPRESSED
}

// =============================================
// 11. DOCUMENT STORAGE (metadata only — file in blob storage)
// =============================================

model Document {
  id          Int      @id @default(autoincrement())
  uuid        String   @unique @default(cuid())
  fileName    String   @db.VarChar(255)
  mimeType    String   @db.VarChar(100)
  fileUrl     String   @db.VarChar(1000)  // Blob storage URL (replaces VARBINARY)
  fileSize    Int?
  uploadedBy  String?  @db.VarChar(50)
  uploadedAt  DateTime @default(now())
  assetId     Int?

  asset       Asset?   @relation(fields: [assetId], references: [id])

  @@map("documents")
}

// =============================================
// 12. IN-APP NOTIFICATIONS
// =============================================

model InAppNotification {
  id         Int      @id @default(autoincrement())
  employeeId String   @db.VarChar(20)
  title      String   @db.VarChar(255)
  message    String   @db.Text
  type       String   @db.VarChar(50)
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  linkPath   String?  @db.VarChar(255)
  assetId    Int?
  isDeleted  Boolean  @default(false)

  employee   User     @relation(fields: [employeeId], references: [id])
  asset      Asset?   @relation(fields: [assetId], references: [id])

  @@index([employeeId, isRead, createdAt(sort: Desc)])
  @@map("in_app_notifications")
}
