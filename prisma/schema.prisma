generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model AssetType {
  id           Int      @id @default(autoincrement())
  categoryName String   @db.VarChar(20)
  typeName     String   @db.VarChar(50)
  createdAt    DateTime @default(now())
  assets       Asset[]

  @@unique([categoryName, typeName])
  @@index([categoryName])
  @@map("asset_types")
}

model Vendor {
  id         String   @id @db.VarChar(20)
  vendorName String   @db.VarChar(150)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  isDeleted  Boolean  @default(false)
  isBlocked  Boolean  @default(false)
  assets     Asset[]

  @@map("vendors")
}

model User {
  id                String    @id @db.VarChar(20)
  fullName          String    @db.VarChar(100)
  department        String?   @db.VarChar(50)
  email             String?   @db.VarChar(255)
  password          String?   @db.VarChar(255)
  role              UserRole  @default(Viewer)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  isDeleted         Boolean   @default(false)
  isBlocked         Boolean   @default(false)
  lastLogoutAt      DateTime?
  managedCategories String?   @default("ALL") @db.VarChar(500)

  allocations        Allocation[]
  assetHistory       AssetHistory[]
  inAppNotifications InAppNotification[]
  maintenanceReports Maintenance[]       @relation("ReportedByUser")

  @@index([role])
  @@map("users")
}

model Asset {
  id                Int                 @id @default(autoincrement())
  assetCode         String              @unique @db.VarChar(20)
  assetName         String              @db.VarChar(150)
  assetTypeId       Int
  invoiceNumber     String?             @db.VarChar(50)
  invoiceDate       DateTime?           @db.Date
  vendorId          String?             @db.VarChar(20)
  purchasePrice     Decimal             @default(0) @db.Decimal(18, 2)
  purchaseNumber    String?             @db.VarChar(50)
  prNumber          String?             @db.VarChar(50)
  importBillUrl     String?             @db.VarChar(500)
  serialNumber      String?             @db.VarChar(50)
  model             String?             @db.VarChar(50)
  ram               String?             @db.VarChar(20)
  storage           String?             @db.VarChar(20)
  processor         String?             @db.VarChar(50)
  macAddress        String?             @db.VarChar(20)
  portCount         Int?
  portSpeed         String?             @db.VarChar(20)
  totalQuantity     Int                 @default(1)
  allocatedQuantity Int                 @default(0)
  licenseExpiryDate DateTime?           @db.Date
  licenseType       LicenseType?
  status            AssetStatus         @default(Available)
  disposalDate      DateTime?           @db.Date
  disposalReason    String?             @db.VarChar(255)
  condition         AssetCondition?
  isBulkOrder       Boolean             @default(false)
  bulkOrderParentId Int?
  bulkOrderIndex    Int?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  isDeleted         Boolean             @default(false)
  allocations       Allocation[]
  parentAllocations Allocation[]        @relation("ParentAssetAllocations")
  history           AssetHistory[]
  parentHistory     AssetHistory[]      @relation("ParentAssetHistory")
  assetType         AssetType           @relation(fields: [assetTypeId], references: [id])
  bulkParent        Asset?              @relation("BulkChildren", fields: [bulkOrderParentId], references: [id])
  bulkChildren      Asset[]             @relation("BulkChildren")
  vendor            Vendor?             @relation(fields: [vendorId], references: [id])
  documents         Document[]
  notifications     InAppNotification[]
  maintenance       Maintenance[]

  @@index([status])
  @@index([assetTypeId])
  @@index([vendorId])
  @@index([updatedAt(sort: Desc)])
  @@index([assetCode])
  @@index([isDeleted, status])
  @@map("assets")
}

model Allocation {
  id                    Int              @id @default(autoincrement())
  assetId               Int
  employeeId            String?          @db.VarChar(20)
  parentAssetId         Int?
  allocationDate        DateTime         @default(now())
  returnDate            DateTime?
  installationLocation  String?          @db.VarChar(150)
  ipAddress             String?          @db.VarChar(45)
  operatingSystem       String?          @db.VarChar(50)
  conditionAtAllocation AssetCondition   @default(GOOD)
  conditionAtReturn     AssetCondition?
  status                AllocationStatus @default(ACTIVE)
  returnNotes           String?          @db.VarChar(255)
  assignedBy            String?          @db.VarChar(100)
  returnedBy            String?          @db.VarChar(100)
  createdAt             DateTime         @default(now())
  isDeleted             Boolean          @default(false)
  asset                 Asset            @relation(fields: [assetId], references: [id])
  employee              User?            @relation(fields: [employeeId], references: [id])
  parentAsset           Asset?           @relation("ParentAssetAllocations", fields: [parentAssetId], references: [id])

  @@index([assetId])
  @@index([employeeId])
  @@index([parentAssetId])
  @@index([status])
  @@index([returnDate])
  @@index([ipAddress])
  @@map("allocations")
}

model Maintenance {
  id                Int                   @id @default(autoincrement())
  assetId           Int
  scheduledDate     DateTime
  completedDate     DateTime?
  description       String                @db.VarChar(255)
  notes             String?
  status            MaintenanceStatus     @default(Scheduled)
  technician        String?               @db.VarChar(100)
  cost              Decimal               @default(0) @db.Decimal(18, 2)
  frequency         MaintenanceFrequency?
  isBulkGroupRecord Boolean               @default(false)
  unitCount         Int?
  reportedBy        String?               @db.VarChar(20)
  isDeleted         Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  asset             Asset                 @relation(fields: [assetId], references: [id])
  reporter          User?                 @relation("ReportedByUser", fields: [reportedBy], references: [id])
  notifications     NotificationQueue[]

  @@index([assetId])
  @@index([scheduledDate])
  @@index([status])
  @@index([isDeleted, status])
  @@map("maintenance")
}

model AssetHistory {
  id              Int      @id @default(autoincrement())
  assetId         Int
  employeeId      String?  @db.VarChar(20)
  actionType      String   @db.VarChar(50)
  actionDate      DateTime @default(now())
  performedBy     String?  @db.VarChar(100)
  notes           String?
  condition       String?  @db.VarChar(20)
  parentAssetId   Int?
  parentAssetName String?  @db.VarChar(150)
  asset           Asset    @relation(fields: [assetId], references: [id])
  employee        User?    @relation(fields: [employeeId], references: [id])
  parentAsset     Asset?   @relation("ParentAssetHistory", fields: [parentAssetId], references: [id])

  @@index([assetId])
  @@index([employeeId])
  @@index([actionDate(sort: Desc)])
  @@index([actionType])
  @@index([parentAssetId])
  @@index([assetId, actionType])
  @@map("asset_history")
}

model AuditLog {
  id             Int         @id @default(autoincrement())
  tableName      String      @db.VarChar(50)
  recordId       String?     @db.VarChar(50)
  action         AuditAction
  oldValues      String?
  newValues      String?
  changedBy      String?     @db.VarChar(100)
  changedAt      DateTime    @default(now())
  additionalInfo String?
  isDeleted      Boolean     @default(false)

  @@index([tableName, recordId])
  @@index([changedAt(sort: Desc)])
  @@index([changedBy, changedAt(sort: Desc)])
  @@index([action])
  @@index([tableName, action, recordId])
  @@map("audit_logs")
}

model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String?
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

model NotificationQueue {
  id                   Int                @id @default(autoincrement())
  recipient            String?            @db.VarChar(1000)
  subject              String             @db.VarChar(255)
  body                 String
  type                 String             @db.VarChar(50)
  status               NotificationStatus @default(PENDING)
  createdAt            DateTime           @default(now())
  scheduledFor         DateTime           @default(now())
  sentAt               DateTime?
  errorMessage         String?
  retryCount           Int                @default(0)
  cc                   String?            @db.VarChar(1000)
  metadata             String?
  maintenanceId        Int?
  maintenanceEmailType String?            @db.VarChar(20)
  recipientType        String?            @db.VarChar(50)
  recipientLabel       String?            @db.VarChar(255)
  suppressedBy         String?            @db.VarChar(100)
  suppressedAt         DateTime?
  maintenance          Maintenance?       @relation(fields: [maintenanceId], references: [id])

  @@index([status])
  @@index([maintenanceId])
  @@map("notification_queue")
}

model Document {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(cuid())
  fileName   String   @db.VarChar(255)
  mimeType   String   @db.VarChar(100)
  fileUrl    String   @db.VarChar(1000)
  fileSize   Int?
  uploadedBy String?  @db.VarChar(50)
  uploadedAt DateTime @default(now())
  assetId    Int?
  asset      Asset?   @relation(fields: [assetId], references: [id])

  @@map("documents")
}

model InAppNotification {
  id         Int      @id @default(autoincrement())
  employeeId String   @db.VarChar(20)
  title      String   @db.VarChar(255)
  message    String
  type       String   @db.VarChar(50)
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
  linkPath   String?  @db.VarChar(255)
  assetId    Int?
  isDeleted  Boolean  @default(false)
  asset      Asset?   @relation(fields: [assetId], references: [id])
  employee   User     @relation(fields: [employeeId], references: [id])

  @@index([employeeId, isRead, createdAt(sort: Desc)])
  @@map("in_app_notifications")
}

enum UserRole {
  Admin
  Manager
  Viewer
}

enum AssetStatus {
  Available
  Allocated
  Partially_Allocated @map("Partially Allocated")
  Under_Maintenance   @map("Under Maintenance")
  Disposed
  License_Expired     @map("License Expired")
  Lost
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
}

enum LicenseType {
  PERPETUAL
  SUBSCRIPTION
  SAAS
  TRIAL
  VOLUME
  ENTERPRISE
}

enum AllocationStatus {
  ACTIVE
  RETURNED
  REVOKED
  EXPIRED
}

enum MaintenanceStatus {
  Scheduled
  In_Progress @map("In Progress")
  Completed
  Cancelled
  Reported
}

enum MaintenanceFrequency {
  Monthly
  Quarterly
  Half_Yearly @map("Half-Yearly")
  Yearly
  One_Time    @map("One-Time")
}

enum AuditAction {
  INSERT
  ASSET_INSERT
  UPDATE
  DELETE
  ALLOCATE
  RETURN
  MAINTENANCE
  MAINTENANCE_UPDATE
  MAINTENANCE_START
  MAINTENANCE_END
  MAINTENANCE_SCHEDULE
  MAINTENANCE_CANCEL
  DISPOSE
  LICENSE_RENEWED
  ROLE_CHANGE
  PASSWORD_CHANGE
  USER_BLOCK_TOGGLE
  UNAUTHORIZED_ACCESS
  LOGIN
  LOGOUT
  LOGIN_FAILED
  CREATION
  DELETION
  EMAIL_SENT
  EMAIL_SUPPRESSED
  EMAIL_MERGED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  SUPPRESSED
}

model AssetCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(100)
  fields    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("asset_categories")
}
