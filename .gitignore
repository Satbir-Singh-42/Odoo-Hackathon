# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/build

# misc
.DS_Store
*.pem
Thumbs.db
ehthumbs.db
Desktop.ini

# debug & logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs
*.log.*

# env files (NEVER commit secrets to git!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
# Ensure example templates remain tracked
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma & local databases
/prisma/*.db
/prisma/*.db-journal

# ide & local agents
.vscode
.idea
.gemini
.agents
